{
  "info": {
    "_postman_id": "mini-ai-sdr-collection",
    "name": "Mini AI SDR API",
    "description": "Complete API collection for the Mini AI SDR application. Set the `base_url` variable to `http://localhost:8000` and use the Login request to auto-populate the `token` variable.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "lead_id", "value": "1", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Jane Smith\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"SecurePass123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.access_token);",
                  "  console.log('Token saved:', json.access_token.substring(0,20) + '...');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo@minisdr.com\",\n  \"password\": \"Demo@123456\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.access_token);",
                  "  console.log('Logged in as:', json.user.email);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/auth/me", "host": ["{{base_url}}"], "path": ["api", "auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "Leads",
      "item": [
        {
          "name": "Create Lead",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/leads", "host": ["{{base_url}}"], "path": ["api", "leads"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alex Johnson\",\n  \"email\": \"alex.johnson@techstartup.com\",\n  \"company\": \"TechStartup Inc\",\n  \"job_title\": \"CTO\",\n  \"industry\": \"Software & Technology\",\n  \"linkedin_url\": \"https://linkedin.com/in/alexjohnson\",\n  \"notes\": \"Met at a conference. Very interested in AI tools for their sales team.\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('lead_id', json.id.toString());",
                  "  console.log('Lead created with ID:', json.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List Leads",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/leads?skip=0&limit=50",
              "host": ["{{base_url}}"],
              "path": ["api", "leads"],
              "query": [
                { "key": "skip", "value": "0" },
                { "key": "limit", "value": "50" }
              ]
            }
          }
        },
        {
          "name": "Get Lead by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/leads/{{lead_id}}", "host": ["{{base_url}}"], "path": ["api", "leads", "{{lead_id}}"] }
          }
        },
        {
          "name": "Update Lead",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/leads/{{lead_id}}", "host": ["{{base_url}}"], "path": ["api", "leads", "{{lead_id}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"contacted\",\n  \"notes\": \"Followed up via email. Scheduled a demo for next week.\"\n}"
            }
          }
        },
        {
          "name": "Delete Lead",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/leads/{{lead_id}}", "host": ["{{base_url}}"], "path": ["api", "leads", "{{lead_id}}"] }
          }
        }
      ]
    },
    {
      "name": "AI",
      "item": [
        {
          "name": "Qualify Lead (OpenAI)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/ai/qualify/{{lead_id}}", "host": ["{{base_url}}"], "path": ["api", "ai", "qualify", "{{lead_id}}"] }
          }
        },
        {
          "name": "Generate Email (Gemini)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/ai/email/{{lead_id}}", "host": ["{{base_url}}"], "path": ["api", "ai", "email", "{{lead_id}}"] }
          }
        },
        {
          "name": "Get Lead Emails",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/ai/emails/{{lead_id}}", "host": ["{{base_url}}"], "path": ["api", "ai", "emails", "{{lead_id}}"] }
          }
        }
      ]
    },
    {
      "name": "LangGraph Agent",
      "item": [
        {
          "name": "Run SDR Agent Pipeline",
          "description": "Runs the full LangGraph agent for a lead:\n1. qualify_lead — scores the lead 0-100 using OpenAI/Groq\n2. finalize — compiles results and timestamps completion",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/agent/run/{{lead_id}}", "host": ["{{base_url}}"], "path": ["api", "agent", "run", "{{lead_id}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  console.log('Agent completed. Score:', json.qualification_score);",
                  "  console.log('Email generated:', json.email_generated);",
                  "  console.log('Nodes executed:', json.logs.length);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Utility",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/health", "host": ["{{base_url}}"], "path": ["api", "health"] }
          }
        },
        {
          "name": "API Docs",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/docs", "host": ["{{base_url}}"], "path": ["api", "docs"] }
          }
        }
      ]
    }
  ]
}
